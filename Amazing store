<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Handmade Fashion Boutique</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav>
        <div class="logo">HER NAME/BRAND</div>
        <ul>
            <li><a href="#shop">Shop</a></li>
            <li><a href="#about">Our Story</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <header class="hero">
        <div class="hero-content">
            <h1>Handmade Elegance</h1>
            <p>Custom-tailored outfits designed specifically for you.</p>
            <a href="#shop" class="btn">View Collection</a>
        </div>
    </header>

    <section id="shop" class="products">
        <h2>The Collection</h2>
        <div class="grid">
            <div class="item">
                <img src="https://via.placeholder.com/300x400" alt="Dress">
                <h3>Floral Summer Dress</h3>
                <p>₦25,000</p>
                <button class="buy-btn">Add to Cart</button>
            </div>
            <div class="item">
                <img src="https://via.placeholder.com/300x400" alt="Top">
                <h3>Silk Wrap Top</h3>
                <p>₦15,000</p>
                <button class="buy-btn">Add to Cart</button>
            </div>
        </div>
    </section>

</body>
</html>
